{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["import", "typescript", "react"],
	"env": {
		"browser": true,
		"node": true
	},
	"settings": {
		"react": {
			"version": "18"
		}
	},
	"rules": {
		"no-unused-vars": "warn",
		"no-console": "off"
	},
	"ignorePatterns": ["node_modules", "build", "public/build", ".react-router"]
}
